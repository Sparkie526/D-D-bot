# Required: Discord Bot Configuration
DISCORD_TOKEN=

# Required: ElevenLabs Text-to-Speech
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Ollama Configuration
# For Docker Compose: use http://ollama:11434/api/chat
# For local: use http://localhost:11434/api/chat
OLLAMA_URL=http://ollama:11434/api/chat
OLLAMA_MODEL=mistral

# LLM Provider
# - openai: uses OpenAI Chat Completions
# - ollama: uses local Ollama server
LLM_PROVIDER=openai

# OpenAI Configuration
OPENAI_MODEL=gpt-4o-mini

# Optional: OpenAI API (used for LLM provider and/or future Whisper)
OPENAI_API_KEY=

# World Selection
# Optional: specify a world file to use (e.g. ashmore_keep.txt)
# If not set, a random world from worlds/ folder will be chosen
# WORLD_FILE=ashmore_keep.txt
