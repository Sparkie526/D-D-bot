# Required: Discord Bot Configuration
DISCORD_TOKEN=

# Required: ElevenLabs Text-to-Speech
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Ollama Configuration
# For Docker Compose: use http://ollama:11434/api/chat
# For local: use http://localhost:11434/api/chat
OLLAMA_URL=http://ollama:11434/api/chat
OLLAMA_MODEL=mistral

# Optional: OpenAI API (for future Whisper integration)
OPENAI_API_KEY=
